FROM node:22-slim AS node-runtime

FROM python:3.12-slim

ARG INSTALL_CODEX=true

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV CODEX_HOME=/auth/codex
ENV GH_CONFIG_DIR=/auth/gh
ENV GH_PUBLIC_CONFIG_DIR=/auth/gh-public
ENV GH_STUDYOS_ORG_CONFIG_DIR=/auth/gh-studyos-org

WORKDIR /app

COPY --from=node-runtime /usr/local/ /usr/local/

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates curl git graphviz openssh-client \
  && mkdir -p -m 755 /etc/apt/keyrings \
  && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    -o /etc/apt/keyrings/githubcli-archive-keyring.gpg \
  && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
  && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    > /etc/apt/sources.list.d/github-cli.list \
  && apt-get update \
  && apt-get install -y --no-install-recommends gh \
  && rm -rf /var/lib/apt/lists/*

RUN if [ "$INSTALL_CODEX" = "true" ]; then npm install -g @openai/codex; fi

COPY pyproject.toml README.md LICENSE ./
COPY codex ./codex
COPY src ./src

RUN mkdir -p "$CODEX_HOME" && cp ./codex/config.toml "$CODEX_HOME/config.toml"

RUN pip install --no-cache-dir .

EXPOSE 8080

CMD ["sh", "-c", "set -eu; mkdir -p \"$CODEX_HOME\"; if [ -f /app/codex/config.toml ] && [ ! -f \"$CODEX_HOME/config.toml\" ]; then cp /app/codex/config.toml \"$CODEX_HOME/config.toml\"; fi; if [ -d /app/codex/automations ]; then mkdir -p \"$CODEX_HOME/automations\"; cp -Rn /app/codex/automations/. \"$CODEX_HOME/automations/\"; fi; exec studyos-agent-gateway"]
